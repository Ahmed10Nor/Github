                f"current_task='{current_task[:120]}' | "
                f"last_query='{last_query[:80]}' | "
                f"behavioral_score={b_score}/2 | "
                f"stage_week={stage['current_week']} "
                f"incomplete={stage['incomplete']}/{stage['total']} | "
                f"failure_streak={streak}"
            )

            consensus = await run_consensus(profile, "background_discourse", context)

            log_agent(user_id, "orchestrator", "background_discourse_verdict",
                      f"action={consensus.action} | {consensus.decision[:120]}",
                      route="background_discourse", tokens_est=0)

            send = consensus.action != "proceed" or b_score > 0 or streak > 0
            if not send:
                log_agent(user_id, "orchestrator", "background_discourse_clear",
                          "action=proceed + zero signals -> no interrupt",
                          route="background_discourse", tokens_est=0)
                return

            # v6.4: Clean user-facing prompt — zero internal system terms
            lang = profile.language
            if lang == "ar":
                tone = (
                    "تحدٍّ تكتيكي إضافي" if consensus.action == "proceed_adjusted"
                    else "تدخل استراتيجي"
                )
                prompt = (
                    f"أنت مدرب تعليمي متقدم في Lumin — ردودك مخصصة ومباشرة.\n\n"
                    f"الاسم: {profile.name} | الهدف: {profile.goal} | المستوى: {profile.level}\n"
                    f"المهمة النشطة: {current_task}\n"
                    f"آخر سؤال: {last_query}\n\n"
                    f"اكتب رسالة {tone} (3 جمل فقط) بالعربية تُشير مباشرةً إلى المهمة والسؤال. "
                    f"اقترح خطوة تكتيكية محددة قابلة للتنفيذ الآن.\n"
                    f"قاعدة صارمة: لا تذكر Coach, Fixer, consensus, streak, stage-gate, agent_log, "
                    f"LuminAgents، أو أي مصطلح تقني داخلي. تحدث مع المستخدم مباشرة فقط."
                )
            else:
                tone = (
                    "tactical optimization challenge" if consensus.action == "proceed_adjusted"
                    else "strategic coaching check-in"
                )
                prompt = (
                    f"You are an advanced learning coach at Lumin — "
                    f"sharp, specific, zero filler.\n\n"
                    f"Name: {profile.name} | Goal: {profile.goal} | Level: {profile.level}\n"
                    f"Active task: {current_task}\n"
                    f"Last query: {last_query}\n\n"
                    f"Write a {tone} message (3 sentences only) that directly references "
                    f"the active task and last query. Propose one immediately actionable step.\n"
                    f"Hard rule: never mention Coach, Fixer, consensus, streak, stage-gate, "
                    f"agent_log, LuminAgents, or any internal system term. "
                    f"Speak directly to the user only."
                )

            outbound = await loop.run_in_executor(
                None, lambda: call_llm(prompt, max_tokens=2048, thinking_budget=0)
            )

            action_icon = {"rebuild": "🚨", "simplify": "⚡", "proceed_adjusted": "🎯"}.get(
                consensus.action, "🔔"
            )
            label = action_icon + " " + (
                "تقييم استراتيجي" if lang == "ar" else "Strategic Assessment"
            )
            await bot.send_message(chat_id=chat_id, text=f"{label}\n\n{outbound}")

            log_agent(user_id, "orchestrator", "background_discourse_sent",
                      f"action={consensus.action} b_score={b_score} -> chat_id={chat_id}",
                      route="background_discourse", tokens_est=150)

        except Exception as e:
            try:
                log_agent(user_id, "orchestrator", "background_discourse_error",
                          str(e)[:200], route="background_discourse")
            except Exception:
                pass

    def _get_discourse_context(self, user_id: str) -> tuple:
        try:
            conn = get_connection()
            task_row = conn.execute(
                "SELECT description FROM daily_tasks "
                "WHERE user_id=? AND completed=0 ORDER BY day ASC LIMIT 1",
                (user_id,),
            ).fetchone()
            current_task = task_row["description"] if task_row else "general study session"
            query_row = conn.execute(
                "SELECT detail FROM agent_log "
                "WHERE user_id=? AND action='fetch' ORDER BY id DESC LIMIT 1",
                (user_id,),
            ).fetchone()
            last_query = query_row["detail"] if query_row else "no recent content queries"
            conn.close()
            return current_task, last_query
        except Exception:
            return "general study session", "no recent content queries"

    def _hard_reset_user(self, user_id: str) -> None:
        conn = get_connection()
        conn.execute("PRAGMA journal_mode=WAL")
        _all_tables = (
            "milestones", "daily_tasks", "tasks", "snapshots",
            "failure_log", "context_frames", "sources",
            "archived_skills", "agent_log", "security_audit",
        )
        for table in _all_tables:
            try:
                conn.execute(f"DELETE FROM {table} WHERE user_id=?", (user_id,))
            except Exception:
                pass
        try:
            conn.execute(
                "UPDATE users SET goal=\'\', category=\'academic\', level=\'beginner\', "
                "estimated_weeks=0, onboarding_complete=0, "
                "onboarding_step=\'awaiting_goal\', partial_profile=NULL, "
                "agent_name=\'Lumin\', agent_vibe=\'Professional\' "
                "WHERE user_id=?",
                (user_id,),
            )
        except Exception:
            pass
        conn.commit()
        conn.close()
        log_agent(user_id, "orchestrator", "hard_reset",
                  "/reset — zero-knowledge wipe complete",
                  route="reset", tokens_est=0)

    async def _handle_identity_change(self, profile, message: str):
        new_name = None
        new_vibe = None
        m_name = _IDENTITY_NAME_RE.search(message)
        if m_name:
            new_name = (m_name.group(1) or m_name.group(2) or "").strip().strip("\"'.,")
        m_vibe = _IDENTITY_VIBE_RE.search(message)
        if m_vibe:
            raw_vibe = (m_vibe.group(1) or m_vibe.group(2) or "").strip().lower()
            new_vibe = _AR_VIBE_MAP.get(raw_vibe, raw_vibe)
        if not new_name and not new_vibe:
            return None
        applied_name = new_name or getattr(profile, 'agent_name', 'Lumin')
        applied_vibe = new_vibe or getattr(profile, 'agent_vibe', 'motivational')
        await self._update_agent_identity(profile.user_id, applied_name, applied_vibe)
        log_agent(profile.user_id, "orchestrator", "identity_change",
                  "name=" + applied_name + ", vibe=" + applied_vibe,
                  route="identity", tokens_est=60)
        if DEMO_MODE:
            return f"Got it! I'll be {applied_name} from now on."
        lang = profile.language
        if lang == "ar":
            prompt = (
                f"المستخدم طلب تغيير اسمك إلى '{applied_name}' "
                f"بأسلوب '{applied_vibe}'. "
                f"رد بجملة واحدة بالعربية تؤكد فيها هذا التغيير."
            )
        else:
            prompt = (
                f"The user asked you to go by '{applied_name}' "
                f"with a '{applied_vibe}' style. "
                f"Reply in one sentence confirming this change."
            )
        loop = asyncio.get_event_loop()
        return await loop.run_in_executor(None, lambda: call_llm(prompt, max_tokens=60))

    async def _update_agent_identity(self, user_id: str, name: str, vibe: str) -> None:
        async with aiosqlite.connect(str(_db_module.DB_PATH)) as conn:
            await conn.execute("PRAGMA journal_mode=WAL")
            await conn.execute(
                "UPDATE users SET agent_name=?, agent_vibe=? WHERE user_id=?",
                (name, vibe, user_id),
            )
            await conn.commit()
