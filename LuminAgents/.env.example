# LuminAgents — Environment Variables Template
# Copy this to .env and fill in your values

# LLM Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=your-gemini-api-key-here

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Allowed Telegram user IDs (comma-separated, leave empty to allow all)
ALLOWED_USERS=123456789,987654321

# Web Search (get from tavily.com)
TAVILY_API_KEY=your-tavily-key-here

# Demo mode — set true to use pre-built responses without hitting APIs
DEMO_MODE=false
